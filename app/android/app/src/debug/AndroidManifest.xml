<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Local dev only: the walking-skeleton server runs over plain HTTP on the
         dev machine (reachable from the emulator at http://10.0.2.2:8080).
         Android blocks cleartext HTTP by default, so allow it in debug builds.
         Production is HTTPS, so this stays out of the release build. -->
    <application android:usesCleartextTraffic="true" />
</manifest>
