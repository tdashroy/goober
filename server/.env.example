# Copy to `.env` for local development (the `.env` file itself is gitignored).
#
# SQLite database location. The server creates the file if it does not exist and
# runs migrations on startup.
DATABASE_URL=sqlite://goober-dev.db

# Address the server binds. 0.0.0.0 so the Android emulator can reach the dev
# machine at http://10.0.2.2:8080.
GOOBER_BIND=0.0.0.0:8080

# Log filter (tracing-subscriber EnvFilter syntax).
RUST_LOG=info
